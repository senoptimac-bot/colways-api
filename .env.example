# ---------------------------------------------------------------------------
# Modèle d'environnement — AUCUN secret réel ici (valeurs vides ou fictives).
# Copier vers .env : cp .env.example .env
# Puis générer APP_KEY : php artisan key:generate (projet Laravel complet)
# Ne jamais committer le fichier .env (il est listé dans .gitignore).
# ---------------------------------------------------------------------------

# --- Application Laravel ---
APP_NAME=Colways
APP_ENV=local
# Laisser vide ici ; artisan key:generate remplit APP_KEY dans votre .env local
APP_KEY=
APP_DEBUG=true
# URL publique de l’API (ex. http://localhost:8000 en développement)
APP_URL=http://localhost:8000

# --- Base de données (remplacer par vos identifiants locaux ou de test) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=colways
DB_USERNAME=root
DB_PASSWORD=

# --- Sanctum : domaines du front qui peuvent utiliser les cookies de session ---
# En prod : lister vos domaines (ex. app.colways.com,localhost)
SANCTUM_STATEFUL_DOMAINS=localhost

# --- Google OAuth ---
# Ces clés doivent correspondre aux IDs générés dans la console Google Cloud
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=

# --- Cloudinary ---
# Utilisé pour le stockage et l'optimisation des images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
